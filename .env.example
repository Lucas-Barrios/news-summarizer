# API keys
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
NEWS_API_KEY=your-newsapi-key-here

# Environment
ENVIRONMENT=development

# API configuration
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# Cost control and local storage
DAILY_BUDGET=5.00
CACHE_DB_PATH=article_cache.sqlite3

# Pipeline scheduling
PIPELINE_LOCK_FILE=pipeline.lock
PIPELINE_LOG_FILE=pipeline.log
SCHEDULE_CATEGORY=technology
SCHEDULE_ARTICLE_LIMIT=5
SCHEDULE_INTERVAL_MINUTES=60

# Email digest
DIGEST_FROM_EMAIL=news@example.com
DIGEST_TO_EMAIL=reader@example.com
DIGEST_MAX_ARTICLES=5
DIGEST_BASE_URL=http://localhost:8000
DIGEST_LOCK_FILE=digest.lock
DIGEST_SEND_HOUR_UTC=8

# Email delivery: smtp or sendgrid
EMAIL_PROVIDER=smtp

# SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=news@example.com
SMTP_PASSWORD=your-smtp-password-here
SMTP_USE_TLS=true

# SendGrid API settings
SENDGRID_API_KEY=your-sendgrid-api-key-here
